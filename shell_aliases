build() {
    if [[ "$PWD" == */cli/azd/extensions/* ]]; then
        azd x build
    elif [[ "$PWD" == */cli/azd ]]; then
        go build -gcflags="all=-N -l" && go install
    else
        go build -gcflags="all=-N -l"
    fi
}

mkd() {
    mkdir -p "$1" && cd "$1"
}

rebase_onto_main() {
    if [ -z "$1" ]; then
        echo "Usage: rebase_onto_main <N>"
        echo "N: Number of commits to rebase from HEAD"
        return 1
    fi
    git rebase HEAD~$1 --onto main
}

# Shell aliases
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

alias c="clear"
alias ff='find . -type f -name'

alias cli="cd cli/azd"
